#!/usr/bin/env bash

set -euo pipefail

usage() {
  cat >&2 <<'EOF'
用法: ndp <config-name> <user@host> [build|push|dry-activate|test|switch|boot] [options] [-- nix-build-options...]

选项:
  -p, --port PORT           指定 SSH 端口
  -S, --ask-sudo-password   激活前先验证 sudo
  --no-substitutes          执行 nix copy 时禁用替代源
  --show-trace
  --impure
  --                        后续参数原样传递给 nix build
  -h, --help                显示帮助
EOF
}

if [ "$#" -gt 0 ]; then
  case "$1" in
    -h|--help)
      usage
      exit 0
      ;;
  esac
fi

if [ "$#" -lt 2 ]; then
  usage
  exit 1
fi

config_name="$1"
target_host="$2"
shift 2

port=""
action="switch"
action_set=0
ask_sudo_password=0
nix_build_args=()
nix_copy_args=(--substitute-on-destination)

while [ "$#" -gt 0 ]; do
  case "$1" in
    test|switch|boot)
      if [ "$action_set" -eq 1 ]; then
        echo "只能指定一个部署动作" >&2
        usage
        exit 1
      fi
      action="$1"
      action_set=1
      shift
      ;;
    build|push|dry-activate)
      if [ "$action_set" -eq 1 ]; then
        echo "只能指定一个部署动作" >&2
        usage
        exit 1
      fi
      action="$1"
      action_set=1
      shift
      ;;
    -p|--port)
      if [ "$#" -lt 2 ]; then
        echo "$1 缺少参数值" >&2
        usage
        exit 1
      fi
      port="$2"
      shift 2
      ;;
    -S|--ask-sudo-password)
      ask_sudo_password=1
      shift
      ;;
    --no-substitutes)
      nix_copy_args=()
      shift
      ;;
    --show-trace|--impure)
      nix_build_args+=("$1")
      shift
      ;;
    --)
      shift
      nix_build_args+=("$@")
      break
      ;;
    *)
      echo "未知参数: $1；任意 nix build 参数请放在 -- 后" >&2
      usage
      exit 1
      ;;
  esac
done

if [ -n "${XDG_RUNTIME_DIR:-}" ]; then
  control_dir="$XDG_RUNTIME_DIR/ndp"
else
  control_dir="${XDG_CACHE_HOME:-$HOME/.cache}/ndp"
fi
install -d -m 0700 "$control_dir"
control_path="$control_dir/%C"

ssh_opts=(
  -o ControlMaster=auto
  -o ControlPersist=10m
  -o "ControlPath=$control_path"
)

if [ -n "$port" ]; then
  ssh_opts+=(-p "$port")
fi

out="$(nix build "${nix_build_args[@]}" ".#nixosConfigurations.${config_name}.config.system.build.toplevel" --print-out-paths)"

if [ "$action" = "build" ]; then
  printf '%s\n' "$out"
  exit 0
fi

ssh "${ssh_opts[@]}" -MNf "$target_host"
trap 'ssh "${ssh_opts[@]}" -O exit "$target_host" >/dev/null 2>&1 || true' EXIT

activate_prefix="$(ssh "${ssh_opts[@]}" "$target_host" 'if command -v run0 >/dev/null 2>&1; then printf "%s" "run0 --background="; else printf "%s" "sudo"; fi')"

if [ "$ask_sudo_password" -eq 1 ] && [ "$activate_prefix" = "sudo" ]; then
  ssh -t "${ssh_opts[@]}" "$target_host" "sudo -v"
fi

NIX_SSHOPTS="$(printf '%q ' "${ssh_opts[@]}")" nix copy --no-check-sigs "${nix_copy_args[@]}" --to "ssh-ng://$target_host" "$out"

if [ "$action" = "push" ]; then
  exit 0
fi

if [ "$action" = "dry-activate" ]; then
  ssh -t "${ssh_opts[@]}" "$target_host" "${activate_prefix} $out/bin/switch-to-configuration dry-activate"
  exit 0
fi

ssh -t "${ssh_opts[@]}" "$target_host" "${activate_prefix} nix-env -p /nix/var/nix/profiles/system --set $out && ${activate_prefix} $out/bin/switch-to-configuration $action"
